// (One-time scaffolding — only create if it doesn't already exist.)
using System.Linq.Expressions;
using Microsoft.EntityFrameworkCore.Query;

namespace EcoReport.Application.Common.Specifications;

public abstract class Specification<T>
{
    public Expression<Func<T, bool>>? Criteria { get; protected set; }
    public List<Expression<Func<T, object>>> Includes { get; } = [];
    public Func<IQueryable<T>, IIncludableQueryable<T, object>>? IncludeChain { get; protected set; }
    public Expression<Func<T, object>>? OrderBy { get; protected set; }
    public Expression<Func<T, object>>? OrderByDescending { get; protected set; }
    public int? Take { get; protected set; }
    public int? Skip { get; protected set; }
    public bool AsNoTracking { get; protected set; } = true;
}


// === FILE: src/EcoReport.Infrastructure/Persistence/SpecificationEvaluator.cs ===
// (One-time scaffolding.)
using Microsoft.EntityFrameworkCore;
using EcoReport.Application.Common.Specifications;

namespace EcoReport.Infrastructure.Persistence;

internal static class SpecificationEvaluator
{
    public static IQueryable<T> Apply<T>(IQueryable<T> input, Specification<T> spec) where T : class
    {
        var q = input;
        if (spec.AsNoTracking) q = q.AsNoTracking();
        if (spec.Criteria is not null) q = q.Where(spec.Criteria);
        foreach (var inc in spec.Includes) q = q.Include(inc);
        if (spec.IncludeChain is not null) q = spec.IncludeChain(q);
        if (spec.OrderBy is not null) q = q.OrderBy(spec.OrderBy);
        else if (spec.OrderByDescending is not null) q = q.OrderByDescending(spec.OrderByDescending);
        if (spec.Skip is int s) q = q.Skip(s);
        if (spec.Take is int t) q = q.Take(t);
        return q;
    }
}


// === FILE: src/EcoReport.Application/Common/Specifications/__ENTITY___Specs/__SPEC__Spec.cs ===
using EcoReport.Domain.Entities;
using EcoReport.Domain.Enums;

namespace EcoReport.Application.Common.Specifications.__ENTITY___Specs;

/// <summary>
/// Reports waiting for officer verification, scoped to a district.
/// BR-OFF-001 (auto-assignment by district), BR-OFF-002 (24h SLA priority).
/// </summary>
public sealed class __SPEC__Spec : Specification<__ENTITY__>
{
    public __SPEC__Spec(string districtCode, int page, int pageSize)
    {
        Criteria = r => r.Status == ReportStatus.Submitted
                     && r.DistrictCode == districtCode;

        Includes.Add(r => r.Media);
        OrderBy = r => r.CreatedAt;
        Skip = (page - 1) * pageSize;
        Take = pageSize;
    }
}


