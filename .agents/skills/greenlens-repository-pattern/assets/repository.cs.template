using Microsoft.EntityFrameworkCore;
using EcoReport.Application.Common.Interfaces.Persistence;
using EcoReport.Domain.Entities;

namespace EcoReport.Infrastructure.Persistence.Repositories;

/// <summary>
/// EF Core implementation of <see cref="I__ENTITY__Repository"/>.
/// Scoped lifetime, same as <see cref="ApplicationDbContext"/>.
/// </summary>
public sealed class __ENTITY__Repository(ApplicationDbContext db) : I__ENTITY__Repository
{
    public Task<__ENTITY__?> GetForVerificationAsync(
        Guid id,
        CancellationToken cancellationToken)
    {
        // Bundle the includes that Verify/Reject/Reassign all need.
        // Putting them here means a handler can never forget one.
        return db.__ENTITY_PLURAL__
            .Include(x => x.Media)
            .Include(x => x.StatusHistory.OrderByDescending(s => s.At).Take(5))
            .Include(x => x.AssignedTeam)
            .FirstOrDefaultAsync(x => x.Id == id, cancellationToken);
    }

    // Implement other interface methods here. For PostGIS/raw SQL queries,
    // prefer NetTopologySuite via EF over FromSqlRaw — keeps it composable.
}


