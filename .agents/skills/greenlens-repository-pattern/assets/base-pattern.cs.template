using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Storage;
using Greenlens.Application.Common.Interfaces.Persistence;
using Greenlens.Domain.Common;

namespace Greenlens.Infrastructure.Persistence;

internal sealed class EfUnitOfWork(
    ApplicationDbContext db,
    IDomainEventDispatcher eventDispatcher) : IUnitOfWork
{
    public async Task<int> SaveChangesAsync(CancellationToken cancellationToken = default)
    {
        // Gom domain events TRƯỚC Save (entity có thể bị detach sau Save).
        var entitiesWithEvents = db.ChangeTracker
            .Entries<Entity>()
            .Where(e => e.Entity.DomainEvents.Count > 0)
            .Select(e => e.Entity)
            .ToList();

        var domainEvents = entitiesWithEvents
            .SelectMany(e => e.DomainEvents)
            .ToList();

        // Persist (interceptors chạy ở đây)
        var rows = await db.SaveChangesAsync(cancellationToken);

        // Clear events trước dispatch — tránh re-fire nếu handler gọi SaveChanges lại
        foreach (var e in entitiesWithEvents) e.ClearDomainEvents();

        // Dispatch SAU commit
        foreach (var domainEvent in domainEvents)
            await eventDispatcher.DispatchAsync(domainEvent, cancellationToken);

        return rows;
    }

    public async Task<IDbTransaction> BeginTransactionAsync(CancellationToken cancellationToken = default)
    {
        var efTx = await db.Database.BeginTransactionAsync(cancellationToken);
        return new EfDbTransaction(efTx);
    }

    private sealed class EfDbTransaction(IDbContextTransaction inner) : IDbTransaction
    {
        public Task CommitAsync(CancellationToken cancellationToken = default)
            => inner.CommitAsync(cancellationToken);

        public Task RollbackAsync(CancellationToken cancellationToken = default)
            => inner.RollbackAsync(cancellationToken);

        public ValueTask DisposeAsync() => inner.DisposeAsync();
    }
}


