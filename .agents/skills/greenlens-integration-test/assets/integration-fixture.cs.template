using MediatR;
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.DependencyInjection;
using NSubstitute;
using Greenlens.Application;
using Greenlens.Application.Common.Interfaces;
using Greenlens.Application.Common.Interfaces.Persistence;
using Greenlens.Infrastructure.Persistence;

namespace Greenlens.Application.IntegrationTests.Fixtures;

/// <summary>
/// Base class for integration tests. Builds a fresh DI container per test class
/// against the shared Postgres container, and resets data via Respawn before
/// each test.
/// </summary>
public abstract class IntegrationTestBase : IAsyncLifetime
{
    private readonly PostgresContainerFixture _fixture;
    protected ServiceProvider Services { get; private set; } = default!;

    protected IntegrationTestBase(PostgresContainerFixture fixture)
    {
        _fixture = fixture;
    }

    public async Task InitializeAsync()
    {
        await _fixture.ResetAsync();

        var services = new ServiceCollection();

        // Real DbContext on the test container
        services.AddDbContext<ApplicationDbContext>(o => o
            .UseNpgsql(_fixture.ConnectionString, np => np.UseNetTopologySuite())
            .UseSnakeCaseNamingConvention());
        services.AddScoped<IApplicationDbContext>(sp =>
            sp.GetRequiredService<ApplicationDbContext>());

        // Application: MediatR + behaviors + validators
        services.AddApplication();

        // Repos & UoW (Infrastructure registration)
        // services.AddPersistence(...)  — call your real registration

        // Mock external boundaries
        services.AddSingleton(Substitute.For<IFileStorage>());
        services.AddSingleton(Substitute.For<IAiClassificationService>());
        services.AddSingleton(Substitute.For<IEmailSender>());
        services.AddSingleton(Substitute.For<ITurnstileVerifier>());

        // ICurrentUser default — test overrides per test if needed
        var currentUser = Substitute.For<ICurrentUser>();
        currentUser.UserId.Returns(Guid.CreateVersion7());
        currentUser.IsInRole(Arg.Any<string>()).Returns(true);
        services.AddScoped<ICurrentUser>(_ => currentUser);

        // Frozen clock for deterministic tests
        var clock = Substitute.For<IDateTimeProvider>();
        clock.UtcNow.Returns(new DateTimeOffset(2026, 5, 9, 10, 0, 0, TimeSpan.Zero));
        services.AddSingleton(clock);

        Services = services.BuildServiceProvider();
    }

    public Task DisposeAsync()
    {
        Services.Dispose();
        return Task.CompletedTask;
    }

    protected ISender Mediator => Services.GetRequiredService<ISender>();

    protected async Task<T> WithDb<T>(Func<ApplicationDbContext, Task<T>> action)
    {
        await using var scope = Services.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        return await action(db);
    }

    protected async Task WithDb(Func<ApplicationDbContext, Task> action)
    {
        await using var scope = Services.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        await action(db);
    }
}
