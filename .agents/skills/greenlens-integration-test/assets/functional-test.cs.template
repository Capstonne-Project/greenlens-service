using System.Net;
using System.Net.Http.Headers;
using System.Net.Http.Json;
using FluentAssertions;
using Greenlens.Api.FunctionalTests.Fixtures;

namespace Greenlens.Api.FunctionalTests.Endpoints.__RESOURCE__;

[Collection("Functional")]
public sealed class __USECASE__Tests(GreenlensWebApplicationFactory factory)
{
    [Fact]
    public async Task Post_HappyPath_Returns201_BR_REP_001()
    {
        // Arrange
        var client = factory.CreateClient();
        var token  = TestAuthHelper.MintToken(Guid.CreateVersion7(), "Citizen");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        var body = new
        {
            latitude = 10.7769,
            longitude = 106.7009,
            category = "Trash",
            severity = "Medium",
            description = "Đống rác lớn ven đường Lý Tự Trọng",
            mediaIds = new[] { Guid.CreateVersion7() },
            isAnonymous = false,
        };

        // Act
        var response = await client.PostAsJsonAsync("/api/v1/reports", body);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.Created);
        response.Headers.Location.Should().NotBeNull();
    }

    [Fact]
    public async Task Post_NoAuth_Returns401()
    {
        // Arrange — no Authorization header
        var client = factory.CreateClient();

        var body = new { /* ... */ };

        // Act
        var response = await client.PostAsJsonAsync("/api/v1/reports", body);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.Unauthorized);
    }

    [Fact]
    public async Task Post_ValidationFail_Returns400_WithProblemDetails()
    {
        // Arrange
        var client = factory.CreateClient();
        var token  = TestAuthHelper.MintToken(Guid.CreateVersion7(), "Citizen");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        var body = new
        {
            latitude  = 35.6762,                     // Tokyo — out of bounds
            longitude = 139.6503,
            category  = "Trash",
            severity  = "Medium",
            mediaIds  = new[] { Guid.CreateVersion7() },
            isAnonymous = false,
        };

        // Act
        var response = await client.PostAsJsonAsync("/api/v1/reports", body);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.BadRequest);

        var problem = await response.Content.ReadFromJsonAsync<ProblemDetailsResponse>();
        problem.Should().NotBeNull();
        problem!.Status.Should().Be(400);
        problem.Extensions.Should().ContainKey("code");
    }

    private sealed record ProblemDetailsResponse(
        string? Type, string? Title, int? Status, string? Detail,
        Dictionary<string, object>? Extensions);
}
