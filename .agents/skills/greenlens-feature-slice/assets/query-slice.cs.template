///
/// Read-only query. Uses AsNoTracking + projection straight to DTO via Mapster.
/// </remarks>
public sealed class __USECASE__QueryHandler(
    // Query handler KHÔNG cần IUnitOfWork — read-only.
    // Inject specific repo (preferred) hoặc IApplicationDbContext nếu entity
    // chưa có repo riêng.
    I__ENTITY__Repository repository,
    ICurrentUser currentUser
) : IRequestHandler<__USECASE__Query, Result<__RESULT_TYPE__>>
{
    public async Task<Result<__RESULT_TYPE__>> Handle(
        __USECASE__Query request,
        CancellationToken cancellationToken)
    {
        // ---- FLAVOR A: single result ---------------------------------------
        var dto = await repository.QueryAsNoTracking()
            .Where(r => r.Id == request.Id)
            .ProjectToType<__RESULT_TYPE__>()
            .FirstOrDefaultAsync(cancellationToken);

        return dto is null
            ? Result<__RESULT_TYPE__>.Failure(Errors.Reports.NotFound)
            : Result<__RESULT_TYPE__>.Success(dto);

