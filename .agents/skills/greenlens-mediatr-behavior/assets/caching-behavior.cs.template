// =============================================================================
// Greenlens — CachingBehavior
// File: src/Greenlens.Application/Common/Behaviors/CachingBehavior.cs
//
// Opt-in caching for queries. A query implements ICacheable to participate.
// Backed by IDistributedCache (Redis in prod, InMemory in dev).
//
// NFR-relevant: BR-MAP-012 (cache map data 10min), leaderboards, hotspots.
// =============================================================================

using MediatR;
using Microsoft.Extensions.Caching.Distributed;
using Microsoft.Extensions.Logging;
using System.Text.Json;
using Greenlens.Domain.Common;

namespace Greenlens.Application.Common.Behaviors;

/// <summary>
/// Marker interface — queries that want to be cached implement this.
/// </summary>
/// <example>
/// public sealed record GetHotspotsQuery(BoundingBox Area) :
///     IRequest&lt;Result&lt;HotspotsDto&gt;&gt;, ICacheable
/// {
///     public string CacheKey  =&gt; $"hotspots:{Area.Hash}";
///     public TimeSpan CacheFor =&gt; TimeSpan.FromMinutes(10);    // BR-MAP-012
/// }
/// </example>
public interface ICacheable
{
    string CacheKey { get; }
    TimeSpan CacheFor { get; }
}

public sealed class CachingBehavior<TRequest, TResponse>(
    IDistributedCache cache,
    ILogger<CachingBehavior<TRequest, TResponse>> logger)
    : IPipelineBehavior<TRequest, TResponse> where TRequest : notnull
{
    private static readonly JsonSerializerOptions Options = new(JsonSerializerDefaults.Web);

    public async Task<TResponse> Handle(
        TRequest request,
        RequestHandlerDelegate<TResponse> next,
        CancellationToken cancellationToken)
    {
        if (request is not ICacheable cacheable)
            return await next();

        var key   = cacheable.CacheKey;
        var bytes = await cache.GetAsync(key, cancellationToken);

        if (bytes is { Length: > 0 })
        {
            try
            {
                var hit = JsonSerializer.Deserialize<TResponse>(bytes, Options);
                if (hit is not null)
                {
                    logger.LogDebug("Cache hit: {Key}", key);
                    return hit;
                }
            }
            catch (JsonException ex)
            {
                logger.LogWarning(ex, "Cache deserialize failed for {Key}, falling through", key);
                // Fall through to handler — stale schema, evict
                await cache.RemoveAsync(key, cancellationToken);
            }
        }

        var response = await next();

        // Only cache successful results
        if (response is IResultBase { IsSuccess: true } || response is not IResultBase)
        {
            try
            {
                var payload = JsonSerializer.SerializeToUtf8Bytes(response, Options);
                await cache.SetAsync(key, payload, new DistributedCacheEntryOptions
                {
                    AbsoluteExpirationRelativeToNow = cacheable.CacheFor,
                }, cancellationToken);
                logger.LogDebug("Cache set: {Key} for {Ttl}", key, cacheable.CacheFor);
            }
            catch (Exception ex)
            {
                logger.LogWarning(ex, "Cache write failed for {Key}", key);
                // Don't fail the request because caching failed
            }
        }

        return response;
    }
}
