// === FILE: src/EcoReport.Application/Common/Interfaces/IApplicationDbContext.cs ===
using Microsoft.EntityFrameworkCore;
using EcoReport.Domain.Entities;

namespace EcoReport.Application.Common.Interfaces;

/// <summary>
/// The Application-layer view of the database. Handlers depend on this, not on
/// the concrete DbContext, so they stay framework-agnostic.
///
/// Add a DbSet here ONLY when handlers should query it directly. Junction tables,
/// history snapshots, and audit logs deliberately stay off this surface — they
/// belong to specific services in Infrastructure.
/// </summary>
public interface IApplicationDbContext
{
    DbSet<User>            Users           { get; }
    DbSet<Report>          Reports         { get; }
    DbSet<ReportMedia>     ReportMedia     { get; }
    DbSet<Comment>         Comments        { get; }
    DbSet<Notification>    Notifications   { get; }
    DbSet<Badge>           Badges          { get; }
    DbSet<UserBadge>       UserBadges      { get; }
    DbSet<PollutionCategory> PollutionCategories { get; }
    DbSet<District>        Districts       { get; }
    DbSet<CleanupTeam>     CleanupTeams    { get; }
    DbSet<TaskAssignment>  TaskAssignments { get; }

    Task<int> SaveChangesAsync(CancellationToken cancellationToken);
}


// === FILE: src/EcoReport.Infrastructure/Persistence/ApplicationDbContext.cs ===
using Microsoft.EntityFrameworkCore;
using EcoReport.Application.Common.Interfaces;
using EcoReport.Domain.Common;
using EcoReport.Domain.Entities;
using EcoReport.Infrastructure.Persistence.Interceptors;
using System.Linq.Expressions;

namespace EcoReport.Infrastructure.Persistence;

public sealed class ApplicationDbContext(
    DbContextOptions<ApplicationDbContext> options)
    : DbContext(options), IApplicationDbContext
{
    public DbSet<User>                Users               => Set<User>();
    public DbSet<Report>              Reports             => Set<Report>();
    public DbSet<ReportMedia>         ReportMedia         => Set<ReportMedia>();
    public DbSet<Comment>             Comments            => Set<Comment>();
    public DbSet<Notification>        Notifications       => Set<Notification>();
    public DbSet<Badge>               Badges              => Set<Badge>();
    public DbSet<UserBadge>           UserBadges          => Set<UserBadge>();
    public DbSet<PollutionCategory>   PollutionCategories => Set<PollutionCategory>();
    public DbSet<District>            Districts           => Set<District>();
    public DbSet<CleanupTeam>         CleanupTeams        => Set<CleanupTeam>();
    public DbSet<TaskAssignment>      TaskAssignments     => Set<TaskAssignment>();

    // Internal-only sets (not exposed via IApplicationDbContext)
    internal DbSet<AuditLog>          AuditLogs           => Set<AuditLog>();
    internal DbSet<OutboxMessage>     OutboxMessages      => Set<OutboxMessage>();

    protected override void OnModelCreating(ModelBuilder modelBuilder)
    {
        // Apply IEntityTypeConfiguration<T> classes from this assembly.
        modelBuilder.ApplyConfigurationsFromAssembly(typeof(ApplicationDbContext).Assembly);

        // Global query filter: hide soft-deleted rows by default.
        // Handlers that need to see them call .IgnoreQueryFilters().
        ApplySoftDeleteFilter(modelBuilder);

        base.OnModelCreating(modelBuilder);
    }

    private static void ApplySoftDeleteFilter(ModelBuilder modelBuilder)
    {
        foreach (var entityType in modelBuilder.Model.GetEntityTypes())
        {
            if (!typeof(SoftDeletableEntity).IsAssignableFrom(entityType.ClrType)) continue;

            var parameter = Expression.Parameter(entityType.ClrType, "e");
            var prop      = Expression.Property(parameter, nameof(SoftDeletableEntity.DeletedAt));
            var nullConst = Expression.Constant(null, typeof(DateTimeOffset?));
            var body      = Expression.Equal(prop, nullConst);
            var lambda    = Expression.Lambda(body, parameter);

            modelBuilder.Entity(entityType.ClrType).HasQueryFilter(lambda);
        }
    }
}


